{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SI v2 Continuous Controller State",
  "description": "Controller state contract supporting IDLE (between epics) and ACTIVE (with current epic) modes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project",
    "controller_mode",
    "controller_status",
    "operation_level",
    "runtime_policy",
    "merge_policy",
    "current_epic",
    "canonical_main_commit",
    "active_work_item_id",
    "active_branch",
    "active_worktree",
    "active_pr",
    "last_completed_work_item_id",
    "last_run_id",
    "last_run_status",
    "consecutive_failures",
    "pause_reason",
    "updated_at"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "project": {"type": "string", "minLength": 1},
    "controller_mode": {"type": "string", "const": "continuous_implementation"},
    "controller_status": {
      "enum": ["READY", "RUNNING", "BLOCKED", "FAILED", "PAUSED", "COMPLETE"],
      "description": "READY/RUNNING are invocation states; PAUSED/BLOCKED/COMPLETE/FAILED are non-invocation. IN_PROGRESS and COMPLETED are queue-item statuses, not controller statuses."
    },
    "operation_level": {"type": "string", "const": "L3_REPOSITORY_ONLY"},
    "runtime_policy": {"type": "string", "const": "FORBIDDEN"},
    "merge_policy": {"type": "string", "const": "HUMAN_ONLY"},
    "current_epic": {"type": ["string", "null"]},
    "canonical_main_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "active_work_item_id": {"type": ["string", "null"]},
    "active_branch": {"type": ["string", "null"]},
    "active_worktree": {"type": ["string", "null"]},
    "active_pr": {"type": ["integer", "null"]},
    "last_completed_work_item_id": {"type": ["string", "null"]},
    "last_run_id": {"type": ["string", "null"]},
    "last_run_status": {"type": ["string", "null"]},
    "consecutive_failures": {"type": "integer", "minimum": 0},
    "pause_reason": {"type": ["string", "null"]},
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
